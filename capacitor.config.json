{
  "appId": "br.com.acacianegocios.vitale",
  "appName": "VITALE",
  "webDir": "www",
  "server": {
    "androidScheme": "https",
    "iosScheme": "https"
  },
  "ios": {
    "contentInset": "always",
    "backgroundColor": "#040608",
    "limitsNavigationsToAppBoundDomains": true
  },
  "android": {
    "backgroundColor": "#040608",
    "allowMixedContent": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1200,
      "backgroundColor": "#040608",
      "showSpinner": false,
      "androidScaleType": "CENTER_CROP"
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#040608"
    }
  }
}
